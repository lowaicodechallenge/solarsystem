# ── LLM Provider ─────────────────────────────────────────────────────────────
# 옵션: upstage | openai | anthropic | ollama
LLM_PROVIDER=upstage

# 모델 직접 지정 (비워두면 provider별 기본값 사용)
# upstage  기본: solar-pro
# openai   기본: gpt-4o-mini
# anthropic기본: claude-haiku-4-5-20251001
# ollama   기본: llama3.2
LLM_MODEL=

# ── Embedding Provider ────────────────────────────────────────────────────────
# 옵션: upstage | openai | local (API 불필요, sentence-transformers 사용)
EMBED_PROVIDER=upstage

# ── Upstage API Keys ──────────────────────────────────────────────────────────
# 서비스별 전용 키 (각각 다른 계정으로 분리 시 사용)
UPSTAGE_LLM_KEY=your_upstage_api_key_here
UPSTAGE_PARSE_KEY=your_upstage_api_key_here
UPSTAGE_CLASSIFY_KEY=your_upstage_api_key_here
UPSTAGE_EXTRACT_KEY=your_upstage_api_key_here

# 단일 키로 운영 시 fallback (위 4개를 비워두면 이 키로 모두 처리)
UPSTAGE_API_KEY=

# ── Other API Keys ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama는 로컬 실행이라 키 불필요. 서버 주소만 설정
OLLAMA_BASE_URL=http://localhost:11434

# ── Google Calendar ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# ── 국민체력100 동영상 API ────────────────────────────────────────────────────
NFA_API_KEY=your_nfa_api_key_here

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
FRONTEND_URL=http://localhost:3000


# ── Google SMTP ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
