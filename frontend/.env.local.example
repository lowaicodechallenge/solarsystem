NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
NEXT_PUBLIC_USER_ID=user_default
# Google Calendar (frontend-only OAuth — Client Secret 불필요)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
# n8n 웹훅 URL (설정 시 문서 업로드가 n8n 워크플로우로 라우팅됨, 비워두면 백엔드 직접 호출)
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678/webhook/solmate/document-upload
